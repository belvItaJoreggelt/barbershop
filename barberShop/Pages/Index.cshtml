@page
@model IndexModel

<div class="py-2">
    @if (Model.Section == "szolgaltatasok")
    {
        ViewData["Title"] = "Szolgáltatások";
        <h1 class="mb-4 ezustFont">Szolgáltatásaink</h1>

        var index = 0;

        @foreach (var szolg in Model.Szolgaltatasok)
        {
            <div class="row egyszolgaltatas szolgLayout shadow-sm mb-3 py-1 px-0 px-md-3 mx-lg-3 py-sm-0 overflow-hidden szolg-kartya"
                style="animation-delay: @(index * 0.950)s;">

                <div class="col-md-5 col-lg-4 position-relative overflow-hidden szolgKep_Nagy" style="min-height: 200px; background: transparent;">
                    @if (!string.IsNullOrEmpty(szolg.KepFajlNeve) || !string.IsNullOrEmpty(szolg.KepFajlNev_Vilagos))
                    {
                        @if (!string.IsNullOrEmpty(szolg.KepFajlNev_Vilagos))
                        {
                            <img src="~/kepek/szolgaltatasok/@szolg.KepFajlNev_Vilagos"
                                 alt="@szolg.Nev" class="position-absolute top-0 start-0 w-100 h-100 kep-vilagos"
                                 style="object-fit: contain; object-position:top; display: block; background: transparent;" />
                        }
                        @if (!string.IsNullOrEmpty(szolg.KepFajlNeve))
                        {
                            <img src="~/kepek/szolgaltatasok/@szolg.KepFajlNeve"
                                 alt="@szolg.Nev" class="position-absolute top-0 start-0 w-100 h-100 kep-sotet"
                                 style="object-fit: contain; object-position:top; display: block; background: transparent;" />
                        }
                    }
                </div>
                <div class="col-md-7 col-lg-8 px-4 pt-4 pb-1 d-flex flex-column szolgReszletekNagy">
                    <h3 class="szoveg_3d h5 mx-auto accentFont"><strong>@szolg.Nev</strong></h3>
                    <p class="mt-1 ezustFont">@(szolg.Leiras ?? "")</p>
                    <h3 class="mt-2 mx-auto h5 accentFont"><strong>Ár: @szolg.Ar.ToString("N0") Ft</strong></h3>
                    <div class="d-flex mt-auto fodrKiv">
                        <a asp-page="/Index" asp-route-szolgaltatasId="@szolg.Id" asp-route-section="fodraszok" class="btn egyGomb ms-auto">Fodrász kiválasztása</a>
                    </div>
                </div>



                <div class="overflow-hidden szolgKep">
                    @if (!string.IsNullOrEmpty(szolg.KepFajlNeve) || !string.IsNullOrEmpty(szolg.KepFajlNev_Vilagos))
                    {
                        @if (!string.IsNullOrEmpty(szolg.KepFajlNev_Vilagos))
                        {
                            <img src="~/kepek/szolgaltatasok/@szolg.KepFajlNev_Vilagos"
                                 alt="@szolg.Nev" class="position-absolute top-0 start-0 w-100 h-100 kep-vilagos"
                                 style="object-fit: cover; object-position:left top; display: block; background: transparent;" />
                        }
                        @if (!string.IsNullOrEmpty(szolg.KepFajlNeve))
                        {
                            <img src="~/kepek/szolgaltatasok/@szolg.KepFajlNeve"
                                 alt="@szolg.Nev" class="position-absolute top-0 start-0 w-100 h-100 kep-sotet"
                                 style="object-fit: cover; object-position:left top; display: block; background: transparent;" />
                        }
                    }
                </div>
                <div class="szolgNev">
                    <h3 class="szoveg_3d h5 ps-2 accentFont">
                        <strong>
                            @if (szolg.Nev == "Hajvágás + szakáll igazítás")
                            {
                                @:Hajvágás +<br>szakáll igazítás
                            }
                            else
                            {
                                @szolg.Nev
                            }
                        </strong>
                    </h3>
                </div>
                <div class="szolgLeiras">
                    <p class="mt-2 ezustFont">@(szolg.Leiras ?? "")</p>
                    <h3 class="mt-2 ps-2 mb-4 h5 accentFont"><strong>Ár: @szolg.Ar.ToString("N0") Ft</strong></h3>
                    <div class="d-flex fodrKiv">
                        <a asp-page="/Index" asp-route-szolgaltatasId="@szolg.Id" asp-route-section="fodraszok" class="btn speckoGomb ms-auto">Fodrász kiválasztása</a>
                    </div>
                </div>
                @{
                    index++; 
                }
            </div>
        }
    }
    else if(Model.Section =="fodraszok")
    {
        ViewData["Title"] = "Fodrászaink";
        <h1 class="mb-2 mb-sm-1 ezustFont">Fodrász kiválasztása</h1>

        <div class="mb-4 p-3">
            <a asp-page="/Index" asp-route-section="szolgaltatasok" class="btn egyGomb btn-sm mb-3">Vissza a szolgáltatásokhoz</a>
            <p class="ezustFont mb-3">Szolgáltatás: <strong>@Model.KivalasztottSzolgaltatas.Nev</strong></p>
            <p class="ezustFont mb-3">Várható időtartam: <strong>@Model.KivalasztottSzolgaltatas.Idotartam perc</strong></p>

            @if (Model.Fodraszok.Count == 0)
            {
                <p class="ezustFont mb-0">Ehhez a szolgáltatáshoz jelenleg nincs elérhető fodrász.</p>
            }
            else
            {
                var fodraszIndex = 0;
                @foreach (var fodrasz in Model.Fodraszok)
                {
                    var legkorabbi = Model.FodraszLegkorabbiSzabadIdopontok.GetValueOrDefault(fodrasz.ID);

                    <div class="row egyszolgaltatas shadow-sm mb-3 p-0 overflow-hidden szolg-kartya"
                         style="animation-delay: @(fodraszIndex * 0.90)s;">

                        <div class="col-md-5 col-lg-4 py-3 d-flex align-items-center justify-content-center">
                            @if (!string.IsNullOrEmpty(fodrasz.ProfilkepFajlNeve))
                            {
                                <div class="fodrasz-kep-wrap">
                                    <img src="~/kepek/fodraszok/@fodrasz.ProfilkepFajlNeve"
                                         alt="@fodrasz.Nev"
                                         class="fodraszProfilkep" />
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">Kép</span>
                            }
                        </div>

                        <div class="col-md-7 col-lg-8 py-3 px-3 d-flex flex-column justify-content-center">
                            <h3 class="h5 align-self-center accentFont fw-bold">@fodrasz.Nev</h3>

                            <div class="mt-2 d-flex flex-column align-items-center justify-content-center">
                                @if (legkorabbi != null && legkorabbi.Count > 0)
                                {
                                    <p class="ezustFont small">Legkorábbi időpontok:</p>
                                    <div class="d-flex flex-wrap gap-2 mb-3">
                                        @foreach (var ido in legkorabbi)
                                        {
                                            <a asp-page="/Index"
                                               asp-route-section="foglalas"
                                               asp-route-FodraszId="@fodrasz.ID"
                                               asp-route-szolgaltatasId="@Model.KivalasztottSzolgaltatas.Id"
                                               asp-route-foglalasDatum="@ido.ToString("yyyy-MM-dd")"
                                               asp-route-foglalasIdo="@ido.ToString("HH:mm")"
                                               class="btn egyGomb accentFont btn-sm text-nowrap">@ido.ToString("MM.dd.") @ido.ToString("HH:mm")</a>
                                        }
                                    </div>
                                }
                                <a asp-page="/Index"
                                   asp-route-section="osszesIdopont"
                                   asp-route-szolgaltatasId="@Model.KivalasztottSzolgaltatas.Id"
                                   asp-route-FodraszId="@fodrasz.ID"
                                   asp-route-naptarDatum="@(legkorabbi != null && legkorabbi.Count > 0
                                                                      ? legkorabbi[0].ToString("yyyy-MM-dd")
                                                                      : DateTime.Today.ToString("yyyy-MM-dd"))"
                                   class="btn accentFont egyGomb Osszesgomb btn-sm align-self-center mt-1">
                                    Összes időpont
                                </a>
                            </div>

                        </div>
                    </div>
                    fodraszIndex++;
                }
            }
        </div>
    }
    else if (Model.Section == "osszesIdopont")
    {
        ViewData["Title"] = "Időpont kiválasztása";
        <h1 class="mb-4 ezustFont">Időpont kiválasztása</h1>

        <div class="p-4">
            <p>
                <a asp-page="/Index" asp-route-section="fodraszok" asp-route-szolgaltatasId="@Model.KivalasztottSzolgaltatas.Id" class="btn px-4 egyGomb">Vissza a fodrászokhoz</a>
            </p>

            <div class="card p-2 egyszolgaltatas szolg-kartya d-flex flex-column align-items-center gap-5">
                <div class="card-body">

                    <div class="text-center">
                        <div class="fodrasz-kep-wrap mx-auto">
                            <img src="~/kepek/fodraszok/@Model.KivalasztottF.ProfilkepFajlNeve" alt="@Model.KivalasztottF.Nev" class="fodraszProfilkep" />
                        </div>
                    </div>
                
                    <div class="text-center w-100 gap-2">
                        <p class="h4 mt-2 mx-auto accentFont fw-bold">@Model.KivalasztottF.Nev</p>
                        <p class="h6 mt-2 ezustFont">@Model.KivalasztottSzolgaltatas.Nev - @($"{Model.KivalasztottSzolgaltatas.Idotartam}perc")</p>
                    </div>

                    <div class="d-flex justify-content-center w-100 mt-3">
                        <div class="calendar-widget border rounded p-3 w-100" style="max-width: 320px;"
                             data-szolgaltatas-id="@Model.KivalasztottSzolgaltatas?.Id" data-fodrasz-id="@Model.KivalasztottF?.ID">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-bold ezustFont" id="calendarMonthYear">@DateTime.Now.ToString("yyyy. MMMM")</span>
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn egyGomb" id="calPrev" title="Előző hónap">↑</button>
                                    <button type="button" class="btn egyGomb" id="calNext" title="Következő hónap">↓</button>
                                </div>
                            </div>
                            <table class="table table-bordered table-sm mb-2 small">
                                <thead>
                                    <tr>
                                        <th class="text-center" style="width:14%">H</th>
                                        <th class="text-center" style="width:14%">K</th>
                                        <th class="text-center" style="width:14%">Sze</th>
                                        <th class="text-center" style="width:14%">Cs</th>
                                        <th class="text-center" style="width:14%">P</th>
                                        <th class="text-center" style="width:14%">Szo</th>
                                        <th class="text-center" style="width:14%">V</th>
                                    </tr>
                                </thead>
                                <tbody id="calendarBody"></tbody>
                            </table>
                            <div class="d-flex justify-content-center align-items-center">
                                <button type="button" class="btn btn-sm egyGomb" id="calToday">Ma</button>
                            </div>
                            <input type="hidden" id="naptarDatum" name="NaptarDatum" value="@Model.NaptarDatum" />
                        </div>
                    </div>

                    <div class="col-md-4 mt-2 mx-auto gap-4">
                        @if (!Model.ReggeliIdopontok.Any() &&!Model.DelutaniIdopontok.Any() && !Model.EstiIdopontok.Any())
                        {
                            <p class="ezustFont text-center small">Erre a napra nincs szabad időpont.</p>
                        }
                        else
                        {
                            @if (Model.ReggeliIdopontok.Any())
                            {
                                <span class="accentFont small fw-bold">Délelőtt</span>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var idpont in Model.ReggeliIdopontok)
                                    {
                                        <a asp-page="/Index"
                                           asp-route-section="foglalas"
                                           asp-route-FodraszId="@Model.KivalasztottF.ID"
                                           asp-route-szolgaltatasId="@Model.KivalasztottSzolgaltatas.Id"
                                           asp-route-foglalasDatum="@idpont.ToString("yyyy-MM-dd")"
                                           asp-route-foglalasIdo="@idpont.ToString("HH:mm")"
                                           class="btn ezustGomb btn-sm text-nowrap">
                                            @idpont.ToString("HH:mm")
                                        </a>
                                    }
                                </div>
                            
                            }
                            @if (Model.DelutaniIdopontok.Any())
                            {
                                <span class="accentFont small fw-bold">Délután</span>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var idopont in Model.DelutaniIdopontok)
                                    {
                                        <a asp-page="/Index"
                                           asp-route-section="foglalas"
                                           asp-route-FodraszId="@Model.KivalasztottF.ID"
                                           asp-route-szolgaltatasId="@Model.KivalasztottSzolgaltatas.Id"
                                           asp-route-foglalasDatum="@idopont.ToString("yyyy-MM-dd")"
                                           asp-route-foglalasIdo="@idopont.ToString("HH:mm")"
                                           class="btn ezustGomb btn-sm text-nowrap">
                                            @idopont.ToString("HH:mm")
                                        </a>
                                    }
                                </div>
                            }
                            @if (Model.EstiIdopontok.Any())
                            {
                                <span class="accentFont small fw-bold">Este</span>
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var idopont in Model.EstiIdopontok)
                                    {
                                        <a asp-page="/Index"
                                           asp-route-section="foglalas"
                                           asp-route-FodraszId="@Model.KivalasztottF.ID"
                                           asp-route-szolgaltatasId="@Model.KivalasztottSzolgaltatas.Id"
                                           asp-route-foglalasDatum="@idopont.ToString("yyyy-MM-dd")"
                                           asp-route-foglalasIdo="@idopont.ToString("HH:mm")"
                                           class="btn ezustGomb btn-sm text-nowrap">
                                            @idopont.ToString("HH:mm")
                                        </a>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (Model.Section=="foglalas")
    {
        ViewData["Title"] = "Foglalás";

        <div class="p-4">
            <a asp-page="/Index" asp-route-section="fodraszok" asp-route-szolgaltatasId="@Model.KivalasztottSzolgaltatas.Id" class="btn egyGomb px-4">Vissza a fodrászokhoz </a>

            <div class="mt-4 px-1 py-2 FoglHatter">
                <p class="ezustFont">Fodrász: <span class="accentFont fw-bold">@Model.KivalasztottF.Nev</span></p>
                <p class="ezustFont">Szolgáltatás: <span class="accentFont fw-bold">@Model.KivalasztottSzolgaltatas.Nev</span></p>
                <p class="ezustFont">Idő: <span class="accentFont fw-bold">@($"{Model.KivalasztottSzolgaltatas.Idotartam}perc")</span></p>
                <p class="ezustFont">Ár: <span class="accentFont fw-bold">@Model.KivalasztottSzolgaltatas.Ar.ToString("N0") Ft</span></p>
                <p class="ezustFont">Dátum: <span class="accentFont fw-bold">@Model.FoglalasDatum </span><span class="ezustFont fw-bold"> @Model.FoglalasIdo</span></p>
                
                <form method="post" asp-page-handler="Foglalas">
                    <input type="hidden" asp-for="FodraszId" />
                    <input type="hidden" asp-for="SzolgaltatasId" />
                    <input type="hidden" asp-for="FoglalasDatum" />
                    <input type="hidden" asp-for="FoglalasIdo" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <p>
                        <label asp-for="UgyfelNev" class="form-label ezustFont">Név:</label>
                        <input asp-for="UgyfelNev" class="form-control" />
                        <span asp-validation-for="UgyfelNev" class="text-danger"></span>
                    </p>
                    <p>
                        <label asp-for="UgyfelEmail" class="form-label ezustFont">E-mail cím:</label>
                        <input asp-for="UgyfelEmail" class="form-control" />
                        <span asp-validation-for="UgyfelEmail" class="text-danger"></span>
                    </p>
                    <p>
                        <label asp-for="UgyfelTelefon" class="form-label ezustFont">Telefonszám:</label>
                        <input asp-for="UgyfelTelefon" class="form-control" />
                        <span asp-validation-for="UgyfelTelefon" class="text-danger"></span>
                    </p>

                    <p>
                        <label asp-for="UgyfelMegjegyzes" class="form-label ezustFont">Megjegyzés:</label>
                        <input asp-for="UgyfelMegjegyzes" class="form-control" />
                    </p>

                   <p class="accentFont fw-bold">Lemondási határidő: <span class="ezustFont">@Model.LemondasiHatarido?.ToString("yyyy.MM.dd HH:mm") </span></p>

                   <p>
                        <label class="form-label ezustFont">
                            <input type="checkbox" asp-for="AdatKezHozzaJ" />
                            Hozzájárulok hogy 
                            <a asp-page="/Privacy" asp-route-section="foglalas" asp-route-fodraszId="@Model.FodraszId" asp-route-szolgaltatasId="@Model.SzolgaltatasId" asp-route-foglalasDatum="@Model.FoglalasDatum" asp-route-foglalasIdo="@Model.FoglalasIdo">
                                adatkezelési tájékoztató
                            </a>
                            ban leírtaknak megfelelően kezelejék az adataimat.
                        </label>
                        <span asp-validation-for="AdatKezHozzaJ" class="text-danger d-block"></span>
                    </p>
                    <div class="text-end mt-3 me-2">
                        <button type="submit" class="btn speckoGomb">Foglalás elküldése</button>
                    </div>
                    
                    
                </form>
            </div>
        </div>

        
    }
    else if(Model.Section=="koszi")
    {
        <p>
            <a asp-page="/Index" asp-route-section="szolgaltatasok" class="btn mx-4 egyGomb">Új foglalás megkezdése</a>
        </p>
        <div class="p-4 mt-4 egyszolgaltatas szolg-kartya d-flex flex-column justify-content-center align-items-center">
            <p class="ezustFont h4 mt-1 text-center">Időpontodat sikeresen rögzítettük!</p>
            <p class="ezustFont h3 mt-3 text-center">Mi gondoskodunk a stílusról, te csak érkezz pontosan!</p>
            <img src="~/kepek//backgrounds/logo.webp" alt="logo" class="mt-2" style="object-fit:contain; max-height:300px;" />
        </div>
    }
</div>

<style>
    /* Kék (alap): világos kép látszik, sötét elrejtve */
    .kep-vilagos { display: block !important; }
    .kep-sotet { display: none !important; }

    [data-theme="barna"] .kep-vilagos,
    [data-theme="arany"] .kep-vilagos {
        display: none !important;
    }

    [data-theme="barna"] .kep-sotet,
    [data-theme="arany"] .kep-sotet {
        display: block !important;
    }

    .row.egyszolgaltatas {
        align-items: stretch;
    }

    

    
    .fodrasz-kep-wrap {
        height: 100%;
        max-height: 140px;
        aspect-ratio: 1 / 1;
        border-radius: 50%;
        overflow: hidden;
        border: 3px solid var(--accent-color);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    
    .fodraszProfilkep {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    
    .szolgKep {
        display: none;
    }

    .szolgNev {
        display: none;
    }

    .szolgLeiras {
        display: none;
    }


    .szolgKep_Nagy {
        border-radius: 12px;
        overflow: hidden;
        display: flex;
    }

    
    .szolgReszletekNagy{
        display: flex;
    }

    @@media (max-width: 768px) {
        .fodrasz-kep-wrap {
            max-height: 70px;
        }

        .szolgLayout {
            display: grid;
            grid-template-columns: auto 1fr;
            grid-template-rows: 150px 150px;
            position: relative;
            width: 98vw;
            padding-left: 0 !important;
            min-height: 0;
        }

        .szolgKep_Nagy {
            display: none !important;
        }

        .szolgReszletekNagy {
            display: none !important;
        }
        
        .szolgKep {
            display: flex;
            height: 100%;
            width: 100%;
            grid-column: 2;
            grid-row: 1;
            position: relative;
            overflow: hidden;
            padding-bottom: 1rem;
            box-sizing: border-box;
            border-bottom-left-radius: 12px;
        }

        .szolgKep img{
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            width: 100%;
            height: calc(100% - 1rem) !important;
            object-fit: cover;
            object-position: top;
            display: block;
            background: transparent;
            border-bottom-left-radius: 12px;
        }

        .szolgKep::after{
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            bottom: 1rem;
            width: 45%;
            border-bottom-left-radius: 12px;
            background: linear-gradient(to right, rgba(255, 255, 255, 0.98) 0%, rgba(255, 255, 255, 0.85) 25%, rgba(255, 255, 255, 0.5) 60%, transparent 100%);
            }

        .szolgNev {
            display: flex;
            grid-column: 1;
            grid-row: 1;
            align-items: center;
            
        }

        .szolgLeiras {
            display: flex;
            grid-column: 1 / 3;
            grid-row: 2;
            flex-direction: column;
        }

        .fodrKiv {
            position: absolute;
            right: 15px;
            bottom: 15px;
        }
    }
    /*
    .table td,
    .table th {
        background: black !important;
        color: #eeeeee !important;
    }

    tr.table-warning label {
        color: #eeeeee;
    }

    .table-hover tbody tr.table-warning:hover > * {
        background-color: black !important;
    }

    .table {
        border-radius: 20px !important;
        border: solid 0.5px #D4AF37;
    }
    
    .calendar-widget{
        border: none !important;
    }
    */
    .calendar-widget td.naptarKivalasztott {
            background: white !important;
            color: var( --accent-color) !important;
    }
</style>
@if (Model.Section == "osszesIdopont")
{
    <script>
    (function () {
        var calYear = @DateTime.Now.Year;
        var calMonth = @(DateTime.Now.Month - 1);
        var selectedDate = null;
        var monthNames = ['Január', 'Február', 'Március', 'Április', 'Május', 'Június', 'Július', 'Augusztus', 'Szeptember', 'Október', 'November', 'December'];

        // Kezdő dátum beállítása a Model.NaptarDatum alapján (ha van)
        var initialDate = '@Model.NaptarDatum';
        if (initialDate) {
            var p = initialDate.split('-');
            if (p.length === 3) {
                calYear = parseInt(p[0], 10);
                calMonth = parseInt(p[1], 10) - 1;
                selectedDate = new Date(calYear, calMonth, parseInt(p[2], 10));
            }
        }

        function buildOsszesIdopontUrl(dateStr) {
            var cw = document.querySelector('.calendar-widget[data-szolgaltatas-id]');
            var params = 'section=osszesIdopont&naptarDatum=' + dateStr;
            if (cw) {
                var sid = cw.getAttribute('data-szolgaltatas-id');
                var fid = cw.getAttribute('data-fodrasz-id');
                if (sid) params += '&szolgaltatasId=' + sid;
                if (fid) params += '&FodraszId=' + fid;
            }
            return '?' + params;
        }

        function render() {
            var first = new Date(calYear, calMonth, 1);
            var last = new Date(calYear, calMonth + 1, 0);
            var startPad = (first.getDay() + 6) % 7;
            var days = last.getDate();
            var today = new Date();
            today.setHours(0, 0, 0, 0);

            document.getElementById('calendarMonthYear').textContent = calYear + '. ' + monthNames[calMonth];
            var tbody = document.getElementById('calendarBody');
            tbody.innerHTML = '';
            var row = document.createElement('tr');

            for (var i = 0; i < startPad; i++) {
                var cell = document.createElement('td');
                cell.className = 'text-muted';
                cell.textContent = '';
                row.appendChild(cell);
            }

            for (var d = 1; d <= days; d++) {
                if (row.children.length === 7) {
                    tbody.appendChild(row);
                    row = document.createElement('tr');
                }
                var cell = document.createElement('td');
                cell.className = 'text-center';
                cell.style.cursor = 'pointer';
                cell.textContent = d;

                var dObj = new Date(calYear, calMonth, d);
                if (selectedDate && selectedDate.getTime() === dObj.getTime()) {
                    cell.classList.add('naptarKivalasztott');
                }
                if (dObj.getTime() === today.getTime()) {
                    cell.classList.add('border-primary');
                }

                cell.addEventListener('click', function () {
                    var day = parseInt(this.textContent, 10);
                    var dateStr = calYear + '-' + String(calMonth + 1).padStart(2, '0') + '-' + String(day).padStart(2, '0');
                    window.location = buildOsszesIdopontUrl(dateStr);
                });

                row.appendChild(cell);
            }

            while (row.children.length > 0 && row.children.length < 7) {
                var emptyCell = document.createElement('td');
                emptyCell.className = 'text-muted';
                row.appendChild(emptyCell);
            }
            if (row.children.length) tbody.appendChild(row);
        }

        document.getElementById('calPrev').addEventListener('click', function () {
            calMonth--;
            if (calMonth < 0) { calMonth = 11; calYear--; }
            render();
        });

        document.getElementById('calNext').addEventListener('click', function () {
            calMonth++;
            if (calMonth > 11) { calMonth = 0; calYear++; }
            render();
        });

        document.getElementById('calToday').addEventListener('click', function () {
            var t = new Date();
            var dateStr = t.getFullYear() + '-' + String(t.getMonth() + 1).padStart(2, '0') + '-' + String(t.getDate()).padStart(2, '0');
            window.location = buildOsszesIdopontUrl(dateStr);
        });

        render();
    })();
</script>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
