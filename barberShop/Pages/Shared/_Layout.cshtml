@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@{
    var oneSignalAppId = Configuration["OneSignal:AppId"] ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BestBarbershop</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/barberShop.styles.css" asp-append-version="true" />
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#0F3460">
    <script src="https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js" defer></script>
    <script>
        window.OneSignalDeferred = window.OneSignalDeferred || [];
        OneSignalDeferred.push(async function (OneSignal) {
            window._oneSignalInstance = OneSignal;
            const appId = "@oneSignalAppId";

            if (!appId) {
                console.warn("OneSignal AppId nincs beállítva.");
                return;
            }

            await OneSignal.init({
                appId: appId,
                serviceWorkerPath: "/push/onesignal/OneSignalSDKWorker.js",
                serviceWorkerParam: { scope: "/push/onesignal/" },
                notifyButton: {
                    enable: false
                }
            });
        });
    </script>
    <style>
    :root{
        --accent-color: #0F3460;
    }

    
    .accentFont{
        background: linear-gradient(to bottom right, #1f72d6 0%, #164d8f 38%, #0F3460 28%, #0F3460 78%, #206cc9 88%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .speckoGomb{
        background: linear-gradient(to right, white 0%, #e8eef5 40%, #a8c4dc 70%, #164d8f 100%);
        border-left: 2px solid #164d8f;
        color: black;
        padding-right: 20px;
    }

    .Osszesgomb{
        background: linear-gradient(to bottom right, #1f72d6 0%, #164d8f 38%, #0F3460 28%, #0F3460 78%, #206cc9 88%);
        color: white;
    }

    .table td,
    .table th {
        background: #0F3460 !important;
        color: #eeeeee !important;
    }
    .table {
        border-color: gray !important;
    }
    .table-hover tbody tr:hover td,
    .table-hover tbody tr:hover th {
        background: #164d8f !important;
        color: white !important;
    }
    
    .FoglHatter{
        background: transparent;
        backdrop-filter: blur(8px);
    }



    [data-theme="barna"]{
        --accent-color: #7A4A2A;
    }
    [data-theme="barna"] .accentFont{
        background: linear-gradient(to bottom right, #695a3f 0%, #bfa27a 38%, #bfa27a 28%, #bfa27a 78%, #7c6a4a 88%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }
    [data-theme="barna"] .speckoGomb{
        background: linear-gradient(to right, white 0%, #ebe6df 40%, #d4c4a8 70%, #bfa27a 100%);
        border-left: 2px solid #bfa27a;
        color: black;
        padding-right: 20px;
    }
    [data-theme="barna"] .egyGomb{
        background: white;
        color: rgb(49, 47, 47);
        border: solid 1px #7A4A2A;
    }
    [data-theme="barna"] .egyGomb:hover{
        background: white;
        color: rgb(49, 47, 47);
        border: solid 1px #7A4A2A;
    }
    [data-theme="barna"] .aktiv{
        color: black;
    }
    [data-theme="barna"] .aktiv:hover{
        color: black;
    }
    [data-theme="barna"] .szolgKep::after{
        background: linear-gradient(to right, rgba(255, 255, 255, 0.98) 0%, rgba(255, 255, 255, 0.85) 25%, rgba(255, 255, 255, 0.5) 60%, transparent 100%);
    }

    [data-theme="barna"] .table td,
    [data-theme="barna"] .table th {
        background: #bfa27a !important;
        color: white !important;
    }
    [data-theme="barna"] .table {
        border-color: #f5f0e6 !important;
    }
    [data-theme="barna"] .table-hover tbody tr:hover td,
    [data-theme="barna"] .table-hover tbody tr:hover th {
        background: #bfa27a !important;
        color: white !important;
    }
    [data-theme="barna"] .calendar-widget td.naptarKivalasztott {
        background: white !important;
        color: black !important;
     }





    [data-theme="arany"]{
        --accent-color: #D4AF37;
    }
    [data-theme="arany"] body{
        background-image: url('/kepek/backgrounds/blacktop.png');
    }
    [data-theme="arany"] .ezustFont{
        color: #eeeeee;
    }
    [data-theme="arany"] .egyszolgaltatas{
        background: rgba(0, 0, 0, 0.7);
    }
    [data-theme="arany"] .accentFont{
        width: fit-content;
        background: linear-gradient( 90deg, #a47e1b 0%, #b69121 8%, #c9a227 16%, #dbb42c 24%, #9a7009 32%, #edc531 40%, #a47e1b 48%, #b69121 56%, #c9a227 64%, #dbb42c 72%, #9a7009 80%, #edc531 88%, #a47e1b 100% );
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }
    [data-theme="arany"] .speckoGomb{
        width: fit-content;
        background: black;
        background-image: linear-gradient( 90deg, #a47e1b 0%, #b69121 8%, #c9a227 16%, #dbb42c 24%, #9a7009 32%, #edc531 40%, #a47e1b 48%, #b69121 56%, #c9a227 64%, #dbb42c 72%, #9a7009 80%, #edc531 88%, #a47e1b 100% );
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        border: solid 1px #D4AF37;
        padding-right: 8px;
        padding-left: 8px;
    }
    [data-theme="arany"] .egyGomb{
        width: fit-content;
        background: black;
        background-image: linear-gradient( 90deg, #a47e1b 0%, #b69121 8%, #c9a227 16%, #dbb42c 24%, #9a7009 32%, #edc531 40%, #a47e1b 48%, #b69121 56%, #c9a227 64%, #dbb42c 72%, #9a7009 80%, #edc531 88%, #a47e1b 100% );
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        border: solid 1px #D4AF37;
    }
    [data-theme="arany"] .egyGomb:hover{
        width: fit-content;
        background: black;
        background-image: linear-gradient( 90deg, #a47e1b 0%, #b69121 8%, #c9a227 16%, #dbb42c 24%, #9a7009 32%, #edc531 40%, #a47e1b 48%, #b69121 56%, #c9a227 64%, #dbb42c 72%, #9a7009 80%, #edc531 88%, #a47e1b 100% );
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        border: solid 1px #D4AF37;
    }
    [data-theme="arany"] .szolgKep::after{
        background: linear-gradient(to right, rgba(0, 0, 0, 0.98) 0%, rgba(0, 0, 0, 0.85) 25%, rgba(0, 0, 0, 0.5) 60%, transparent 100% );
    }
    [data-theme="arany"] .aktiv{
        color: white;
    }
    [data-theme="arany"] .aktiv:hover{
        color: white;
    }

    [data-theme="arany"] .privacyFont{
        color: white;
    }

    [data-theme="arany"] .table td,
    [data-theme="arany"] .table th {
        background: black !important;
        color: #eeeeee !important;
    }
    [data-theme="arany"] .table {
        border-color: #D4AF37 !important;
    }
    [data-theme="arany"] .table-hover tbody tr:hover td,
    [data-theme="arany"] .table-hover tbody tr:hover th {
        background: #1a1a1a !important;
        color: #D4AF37 !important;
    }
    [data-theme="arany"] .calendar-widget{
        border: none !important;
    }
    [data-theme="arany"] .calendar-widget td.naptarKivalasztott {
        background: #D4AF37 !important;
        color: black !important;
    }
    [data-theme="arany"] .ezustGomb {
        color: #eeeeee;
    }
    [data-theme="arany"] .FoglHatter{
        background: none;
        backdrop-filter: none;
    }
    [data-theme="arany"] .fodrMunkIdo{
        border: solid 1px #D4AF37; 
        background: rgba(0, 0, 0, 0.7); 
        backdrop-filter: blur(8px);
    }



    body {
        background: white;
        background-image: url('/kepek/backgrounds/feher_top.png');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: scroll;
        color: rgb(90, 87, 87);
    }

    .privacyFont{

    }

    .aranyFont {
        width: fit-content;
        background: linear-gradient( 90deg, #a47e1b 0%, #b69121 8%, #c9a227 16%, #dbb42c 24%, #9a7009 32%, #edc531 40%, #a47e1b 48%, #b69121 56%, #c9a227 64%, #dbb42c 72%, #9a7009 80%, #edc531 88%, #a47e1b 100% );
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .ezustFont {
        /*color: #eeeeee;*/
        color: rgb(90, 87, 87);
    }
    .ezustGomb {
        /*color: #eeeeee;*/
        border: solid 1px var(--accent-color);
    }

    .egyszolgaltatas {
        border-radius: 20px;
        border-top: 4px solid #bfa27a;
        border-bottom: 4px solid #bfa27a;
        border-top: 4px solid var(--accent-color);
        border-bottom: 4px solid var(--accent-color);
        /*background: rgba(0, 0, 0, 0.7);*/
        background: transparent;
        backdrop-filter: blur(8px);
        overflow: auto;
    }

    .egyGomb {
        background: white;
        color: #0F3460;
        border: solid 0.5px #0F3460;
        transition: transform 0.5s ease;
    }

    .egyGomb:hover {
        background: white;
        color: #0F3460;
        border: solid 0.5px #0F3460;
        transform: scale(1.08);
    }

    .dangerGomb {
        color: darkorange;
        border: solid 1px darkorange;
    }

    .dangerGomb:hover {
        color: darkorange;
        border: solid 1px darkorange;
        transform: scale(1.08);
    }

    .szoveg_3d {
        font-weight: 700;
        letter-spacing: 0.05em;
    }

    .szolg-kartya {
        transform-origin: center;
        opacity: 0;
        animation: szetnyilik 1.2s ease-out forwards;
    }

    @@keyframes szetnyilik {
        from {
            transform: scaleX(0);
            opacity: 0;
        }

        to {
            transform: scaleX(1);
            opacity: 1;
        }
    }
</style>
</head>
<body class="">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">BestBarbershop</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">szolgáltatások</a>
                        </li>                        
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown">szín</a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item tema-valaszto" href="#" data-theme="kek">
                                        <span style="display:inline-block;width:14px;height:14px;background:#2563eb;border-radius:50%;margin-right:6px;vertical-align:middle;"></span>kék
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item tema-valaszto" href="#" data-theme="barna">
                                        <span style="display:inline-block;width:14px;height:14px;background:#7A4A2A;border-radius:50%;margin-right:6px;vertical-align:middle;"></span>barna
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item tema-valaszto" href="#" data-theme="arany">
                                        <span style="display:inline-block;width:14px;height:14px;background:#D4AF37;border-radius:50%;margin-right:6px;vertical-align:middle;"></span>arany
                                    </a>
                                </li>                                
                            </ul>
                        </li>
                        <li class="nav-item">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @if (User.IsInRole("Admin"))
                                {
                                    <a class="nav-link text-dark" asp-page="/Account/AdminFelulet"> 👤 </a>
                                }
                                else if (User.IsInRole("Fodrasz"))
                                {
                                    <a class="nav-link text-dark" asp-page="/Account/FodraszFelulet"> 👤 </a>
                                }
                                else if (User.IsInRole("Mugli"))
                                {
                                    <a class="nav-link text-dark" asp-page="/Account/MugliFelulet"> 👤 </a>
                                }
                                else
                                {
                                    <a class="nav-link text-dark" asp-page="/Account/Login"> 👤 </a>
                                }
                            }
                            else
                            {
                                <a class="nav-link text-dark" asp-page="/Account/Login"> 👤  </a>
                            }
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container" >
            &copy; 2026 - BestBarbershop - <a asp-area="" asp-page="/Privacy">Privacy</a> - <a asp-area="" asp-page="/Kapcsolat">Kapcsolat</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
    
    (function() {
        document.querySelectorAll('.tema-valaszto').forEach(function(el) {
            el.addEventListener('click', function(e) {
                e.preventDefault();
                var tema = this.getAttribute('data-theme');
                if (tema === 'kek') {
                    document.documentElement.removeAttribute('data-theme');
                } else {
                    document.documentElement.setAttribute('data-theme', tema);
                }
                try { localStorage.setItem('tema', tema); } catch(x) {}
            });
        });
        try {
        var mentett = localStorage.getItem('tema');
        if (mentett) {
            if (mentett === 'kek') {
                document.documentElement.removeAttribute('data-theme');
            } else {
                document.documentElement.setAttribute('data-theme', mentett);
            }
        } else {
            /* nincs mentve semmi → barna alapból */
            document.documentElement.setAttribute('data-theme', 'barna');
        }
    } catch(x) {}
    })();
</script>
</body>
</html>


