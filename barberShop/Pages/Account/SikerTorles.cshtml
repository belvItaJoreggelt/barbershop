@page
@model barberShop.Pages.Account.SikerTorlesModel
@{
}
<div class="container py-4">
    @if (Model.Torolt != null)
    {
        <p class="mb-1">
            <a asp-page="/Account/FodraszFelulet" asp-route-section="foglalasaim" class="px-4 btn egyGomb">Vissza</a>
        </p>

        <h2>Sikeresen töröltük az időpontot!</h2>

        <p class="mt-3">
            Kiküldtünk egy e-mail értesítőt, amennyiben személyesen is szeretnéd jelezni az ügyfelednek, azt alábbi elérhetőségeken teheted:
        </p>

        <p class="mt-2">
            Telefon: <a href="tel:@Model.Torolt.CustomerPhone">@Model.Torolt.CustomerPhone</a>
            <br />
            E-mail: <a href="mailto:@Model.Torolt.CustomerEmail">@Model.Torolt.CustomerEmail</a>
        </p>

        <p class="mt-2">
            Időpont: <span class="accentFont fw-bold">@BudapestTime.UtcToBudapest(Model.Torolt.EsedekessegiIdopont).ToString("yyyy.MM.dd HH:mm")</span>
            <br />
            Név: <span class="accentFont fw-bold">@Model.Torolt.CustomerNeve</span>
            <br />
            Szolgáltatás: <span class="accentFont fw-bold">@Model.Torolt.Szolgaltatas?.Nev</span>
        </p>

    }
    else
    {
        
        <p>
            <a asp-page="/Account/FodraszFelulet" asp-route-section="foglalasaim" class="px-4">Vissza</a>
        </p>
        <h1>
            Sajnos nem található a törölt időpont részletei.
        </h1>
    }
    
</div>
