@page
@model barberShop.Pages.Account.MugliFeluletModel
@{
    ViewData["Title"] = "Felhasználói felület";
}

<div class="container py-4">
   
    @if (string.IsNullOrEmpty(Model.Section))
    {
        <p>
            <a asp-page="/Account/Login" class="px-4 btn aranyFont egyGomb">kijelentkezés</a>
        </p>
        <div class="row gap-4">
            <div class="col-md-4">
                <div class="card h-100 egyszolgaltatas szolg-kartya">
                    <div class="card-header aranyFont">Adataim</div>
                    <div class="card-body d-flex flex-column flex-grow-1">
                        <p class="ezustFont">a profilodhoz tartozó adatok megtekintése és szerkesztése</p>
                        <div class="mt-auto ms-auto">
                            <a asp-page="/Account/MugliFelulet" asp-route-section="adataim" class="btn btn-sm egyGomb aranyFont">tovább</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 egyszolgaltatas szolg-kartya">
                    <div class="card-header aranyFont">Foglalásaim</div>
                    <div class="card-body d-flex flex-column flex-grow-1">
                        <p class="ezustFont">foglalásaid megtekintése és lemondása</p>
                        <div class="mt-auto ms-auto">
                            <a asp-page="/Account/MugliFelulet" asp-route-section="foglalasaim" class="btn btn-sm egyGomb aranyFont">tovább</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (Model.Section == "adataim")
    {
        <p class="mb-3">
            <a asp-page="/Account/MugliFelulet" asp-route-section="" class="btn px-4 egyGomb aranyFont">vissza</a>
        </p>
        @if (TempData["Success"]!= null)
        {
            <div class="alert alert-success mb-3">@TempData["Success"]</div>
        }
        <div class="row gap-3">
            <div class="col-md-6 card egyszolgaltatas szolg-kartya">
                <div class="card-header aranyFont">Bejelentkezési adataim</div>
                <div class="card-body d-flex flex-grow-1">
                    <form class="w-100 d-flex flex-column" asp-page-handler="SaveBejelentkezesi">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label class="form-label ezustFont">E-mail cím</label>
                            <input class="form-control" asp-for="EditEmail" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label ezustFont">Új jelszó (hagyd üresen ha nem változtatsz)</label>
                            <input class="form-control" asp-for="EditPassword"/>
                        </div>
                        <div class="mt-auto ms-auto">
                            <button class="btn egyGomb aranyFont">mentés</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-md-6 card egyszolgaltatas szolg-kartya">
                <div class="card-header aranyFont">Egyéb adataim</div>
                <div class="card-body d-flex flex-grow-1">
                    <form class="w-100 d-flex flex-column" asp-page-handler="SaveEgyebAdataim">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label class="form-label ezustFont">Név</label>
                            <input class="form-control" asp-for="EditNev" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label ezustFont">Telefonszám</label>
                            <input class="form-control" asp-for="EditTel" />
                        </div>
                        <div class="mt-auto ms-auto">
                            <button class="btn egyGomb aranyFont">mentés</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    } 
    else if (Model.Section == "foglalasaim")
    {
        <p class="mb-3">
            <a asp-page="/Account/MugliFelulet" asp-route-section="" class="btn px-4 egyGomb aranyFont">vissza</a>
        </p>
    }
</div>

<style>
    .ezustFont {
        color: #eeeeee;
    }

    .aranyFont {
        width: fit-content;
        background: linear-gradient( 90deg, #a47e1b 0%, #b69121 8%, #c9a227 16%, #dbb42c 24%, #9a7009 32%, #edc531 40%, #a47e1b 48%, #b69121 56%, #c9a227 64%, #dbb42c 72%, #9a7009 80%, #edc531 88%, #a47e1b 100% );
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .vilagosBarna {
        background: rgba(245, 238, 225, 0.9);
        background: transparent;
    }

    .egyszolgaltatas {
        border-radius: 20px;
        border-top: 4px solid #D4AF37;
        border-bottom: 4px solid #D4AF37;
        background: black;
        overflow: auto;
    }

    .egyGomb {
        background: #bfa27a;
        background: black;
        color: #D4AF37;
        border: solid 0.5px #D4AF37;
        transition: transform 0.5s ease;
    }

    .egyGomb:hover {
            background: black;
            color: #D4AF37;
            border: solid 0.5px #D4AF37;
            transform: scale(1.08);
    }

    .dangerGomb {
        color: darkorange;
        border: solid 1px darkorange;
    }

    .dangerGomb:hover {
            color: darkorange;
            border: solid 1px darkorange;
            transform: scale(1.08);
    }

    .szolg-kartya {
        transform-origin: center;
        opacity: 0;
        animation: szetnyilik 0.9s ease-out forwards;
    }

    @@keyframes szetnyilik {
        from {
            transform: scaleX(0);
            opacity: 0;
        }

        to {
            transform: scaleX(1);
            opacity: 1;
        }
    }
</style>