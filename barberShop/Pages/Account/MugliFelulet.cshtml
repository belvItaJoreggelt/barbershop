@page
@model barberShop.Pages.Account.MugliFeluletModel
@{
    ViewData["Title"] = "Felhasználói felület";
}

<div class="container py-4">
   
    @if (string.IsNullOrEmpty(Model.Section))
    {
        <p>
            <a asp-page="/Account/Login" class="px-4 btn egyGomb">kijelentkezés</a>
        </p>
        <div class="row gap-4">
            <div class="col-md-4">
                <div class="card h-100 egyszolgaltatas szolg-kartya">
                    <div class="card-header accentFont fw-bold">Adataim</div>
                    <div class="card-body d-flex flex-column flex-grow-1">
                        <p class="ezustFont">a profilodhoz tartozó adatok megtekintése és szerkesztése</p>
                        <div class="mt-auto ms-auto">
                            <a asp-page="/Account/MugliFelulet" asp-route-section="adataim" class="btn btn-sm egyGomb">tovább</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 egyszolgaltatas szolg-kartya">
                    <div class="card-header accentFont fw-bold">Foglalásaim</div>
                    <div class="card-body d-flex flex-column flex-grow-1">
                        <p class="ezustFont">foglalásaid megtekintése és lemondása</p>
                        <div class="mt-auto ms-auto">
                            <a asp-page="/Account/MugliFelulet" asp-route-section="foglalasaim" class="btn btn-sm egyGomb">tovább</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (Model.Section == "adataim")
    {
        <p class="mb-3">
            <a asp-page="/Account/MugliFelulet" asp-route-section="" class="btn px-4 egyGomb">vissza</a>
        </p>
        @if (TempData["Success"]!= null)
        {
            <div class="alert alert-success mb-3">@TempData["Success"]</div>
        }
        <div class="row gap-3">
            <div class="col-md-6 card egyszolgaltatas szolg-kartya">
                <div class="card-header accentFont fw-bold">Bejelentkezési adataim</div>
                <div class="card-body d-flex flex-grow-1">
                    <form class="w-100 d-flex flex-column" asp-page-handler="SaveBejelentkezesi">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label class="form-label ezustFont">E-mail cím</label>
                            <input class="form-control" asp-for="EditEmail" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label ezustFont">Új jelszó (hagyd üresen ha nem változtatsz)</label>
                            <input class="form-control" asp-for="EditPassword"/>
                        </div>
                        <div class="mt-auto ms-auto">
                            <button class="btn accentFont fw-bold">mentés</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-md-6 card egyszolgaltatas szolg-kartya">
                <div class="card-header accentFont fw-bold">Egyéb adataim</div>
                <div class="card-body d-flex flex-grow-1">
                    <form class="w-100 d-flex flex-column" asp-page-handler="SaveEgyebAdataim">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label class="form-label ezustFont">Név</label>
                            <input class="form-control" asp-for="EditNev" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label ezustFont">Telefonszám</label>
                            <input class="form-control" asp-for="EditTel" />
                        </div>
                        <div class="mt-auto ms-auto">
                            <button class="btn egyGomb">mentés</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    } 
    else if (Model.Section == "foglalasaim")
    {
        <p class="mb-3">
            <a asp-page="/Account/MugliFelulet" asp-route-section="" class="btn px-4 egyGomb">vissza</a>
        </p>

        <div class="row gap-3">
            <div class="col-md-7 card h-100 egyszolgaltatas szolg-kartya">
                <div class="card-header accentFont fw-bold">Mai foglalások</div>
                <div class="card-body">
                    
                    @if (Model.Mai_Foglalasaim.Any())
                    {
                        <table class="foglTabla table-borderless">
                            <tbody>
                                @foreach (var idopont in Model.Mai_Foglalasaim)
                                {
                                    <tr class="lathato lenyitoGomb" tabindex="0" style="cursor:pointer">
                                        <td class="text-center accentFont fw-bold text-nowrap">@idopont.EsedekessegiIdopont.ToString("HH:mm")</td>
                                        <td class="text-center ezustFont">@idopont.Szolgaltatas?.Nev</td>
                                        <td class="text-center" style="color:var(--accent-color); font-size:1.2rem;">
                                            <span class="nyil">▼</span>
                                        </td>
                                    </tr>
                                    <tr class="rejtett">
                                        <td colspan="4" class="p-3">
                                            <span class="ezustFont d-block">Fodrász: <span class="accentFont fw-bold">@idopont.Fodrasz?.Nev</span></span>
                                            <span class="ezustFont d-block">Idő: <span class="accentFont fw-bold">@($"{idopont.Szolgaltatas?.Idotartam}perc")</span></span>
                                            <span class="ezustFont d-block">Ár: <span class="accentFont fw-bold">@($"{idopont.Szolgaltatas?.Ar}Ft")</span></span>
                                            <div class="btn btn-sm dangerGomb w-auto mt-2">törlés</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="ezustFont fw-bold">Nincsen foglalásod a mai napra.</p>
                    }
                </div>
            </div>


            <div class="col-md-7 card h-100 egyszolgaltatas szolg-kartya">
                <div class="card-header accentFont fw-bold">További foglalások</div>
                <div class="card-body">
                    
                    @if (Model.Egyeb_Foglalasaim.Any())
                    {
                        <table class="foglTabla table-borderless">
                            <tbody>
                                @foreach (var idopont in Model.Egyeb_Foglalasaim)
                                {
                                    <tr class="lathato lenyitoGomb" tabindex="0" style="cursor:pointer">
                                        <td class="text-center accentFont fw-bold text-nowrap">@idopont.EsedekessegiIdopont.ToString("MM.dd HH:mm")</td>
                                        <td class="text-center ezustFont">@idopont.Szolgaltatas?.Nev</td>
                                        <td class="text-center" style="color:var(--accent-color); font-size:1.2rem;">
                                            <span class="nyil">▼</span>
                                        </td>
                                    </tr>
                                    <tr class="rejtett">
                                        <td colspan="4" class="p-3">
                                            <span class="ezustFont d-block">Fodrász: <span class="accentFont fw-bold">@idopont.Fodrasz?.Nev</span></span>
                                            <span class="ezustFont d-block">Idő: <span class="ezustFont">@($"{idopont.Szolgaltatas?.Idotartam}perc")</span></span>
                                            <span class="ezustFont d-block">Ár: <span class="accentFont fw-bold">@($"{idopont.Szolgaltatas?.Ar}Ft")</span></span>
                                            <div class="btn btn-sm dangerGomb w-auto mt-2">törlés</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="ezustFont fw-bold">Nincsenek további foglalásaid.</p>
                    }
                </div>
            </div>
            
        </div>
    }
</div>

<style>
    .foglTabla {
        border-collapse: separate;
        border-spacing: 12px 8px;
    }

    
    .rejtett{
        display:none;
    }
    .nyil {
        transition: transform 0.4s ease;
        display: inline-block;
    }
</style>
<script>
    document.querySelectorAll('.lenyitoGomb').forEach(function(gomb){
         gomb.addEventListener('click', function(){
             var rejtettSor= this.nextElementSibling;
             var nyil=this.querySelector('.nyil');

             if(rejtettSor && rejtettSor.classList.contains('rejtett')){
                 if(rejtettSor.style.display === 'table-row'){
                     rejtettSor.style.display = 'none';
                     if(nyil){
                         nyil.style.transform = 'rotate(0deg)';
                     }
                 }
                 else{
                     rejtettSor.style.display ='table-row';
                     if(nyil){
                         nyil.style.transform='rotate(180deg)';
                     }
                 }
             }
         });
     });
</script>