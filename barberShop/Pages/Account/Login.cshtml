@page
@model barberShop.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Bejelentkezés";
}

<div class="container py-4">
    <div class="row gap-3">
        <a asp-page="/Account/Login" asp-route-section="bejelentkezes" class="valaszto btn aktiv" id="valaszto1">
            <h3> Bejelentkezés</h3>
        </a>

        <a asp-page="/Account/Registry" class="valaszto btn inaktiv" id="valaszto2">
            <h3> Regisztrálás</h3>
        </a>
    </div>
   
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mb-3">@TempData["SuccessMessage"]</div>
    }
    @if (Model.Section == "bejelentkezes")
    {
        <div class="row urlap">
            <div class="col-md-5">
                <form method="post">
                   
                    <div asp-validation-summary="All" class="text-danger mb-3"> </div>

                    <div class="mt-3">
                        <label asp-for="Input.EmailAddress" class="form-label ezustFont">E-mail</label>
                        <input asp-for="Input.EmailAddress" class="form-control" type="email" />
                        <span asp-validation-for="Input.EmailAddress" class="text-danger"></span>
                    </div>

                    <div class="mt-3">
                        <label asp-for="Input.Password" class="form-label ezustFont">Jelszó</label>
                        <input asp-for="Input.Password" class="form-control" type="password" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="mt-3 form-check">
                        <input asp-for="Input.RememberMe" class="form-check-input" />
                        <label asp-for="Input.RememberMe" class="form-check-label ezustFont">emlékezz rám</label>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary egyGomb">Belépés</button>
                        <a asp-page="/Index" asp-route-section="szolgaltatasok" class="btn btn-outline-secondary">Mégse</a>
                    </div>
                    
                </form>
            </div>
        </div>
    }
    
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .urlap {
        opacity: 0;
        animation: formFade 0.5s ease-in forwards;
    }

    @@keyframes formFade {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .valaszto{
        height: fit-content;
        width: fit-content;
        padding: 10px 25px;
        display: flex;
        justify-content: center;
        align-items: center;
        transition: border-top-color 0.3s ease-in, color 0.3s ease-in;
    }

    .aktiv {
        border-top: solid 1px var(--accent-color);
        
    }

    .aktiv:hover {
            border-top: solid 1px var(--accent-color);
       
    }

    .inaktiv {
        border-top: solid 1px gray;
        color: gray;
    }

    .inaktiv:hover {
        border-top: solid 1px gray;
        color: gray;
    }

    .ezustFont {
        color: #eeeeee;
    }

    
    .szoveg_3d {
        /*color: #1a1a1a;*/
        font-weight: 700;
        letter-spacing: 0.05em;
    }

    .szolg-kartya {
        transform-origin: center;
        opacity: 0;
        animation: szetnyilik 0.9s ease-out forwards;
    }

    @@keyframes szetnyilik {
        from {
            transform: scaleX(0);
            opacity: 0;
        }

        to {
            transform: scaleX(1);
            opacity: 1;
        }
    }

</style>
            
 