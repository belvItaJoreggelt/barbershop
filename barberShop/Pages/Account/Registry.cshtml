@page
@model barberShop.Pages.Account.RegistryModel
@{
}

<div class="container py-4">
    <div class="row gap-3">
        <a asp-page="/Account/Login" asp-route-section="bejelentkezes" class="valaszto btn inaktiv" id="valaszto1">
            <h3> Bejelentkezés</h3>
        </a>

        <a asp-page="/Account/Registry" class="valaszto btn aktiv" id="valaszto2">
            <h3> Regisztrálás</h3>
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mb-3">@TempData["SuccessMessage"]</div>
    }
    <div class="row">
        <div class="col-5">
            <form method="post" asp-page-handler="Regisztracio">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <div class="mt-3">
                    <label class="form-label ezustFont">E-mail cím</label>
                    <input class="form-control" asp-for="RegEmail" />
                </div>

                <div class="mt-3">
                    <label class="form-label ezustFont">Jelszó</label>
                    <input class="form-control" type="password" asp-for="RegPassword" />
                </div>

                <div class="mt-3">
                    <label class="form-label ezustFont">Név</label>
                    <input class="form-control" asp-for="RegNev" />
                </div>

                <div class="mt-3">
                    <label class="form-label ezustFont">Telefonszám</label>
                    <input class="form-control" asp-for="RegTelo" />
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary egyGomb">Regisztráció</button>
                    <a asp-page="/Index" asp-route-section="szolgaltatasok" class="btn btn-outline-secondary">Mégse</a>
                </div>
            </form>
        </div>
    </div>
</div>
<style>
    .valaszto {
        height: fit-content;
        width: fit-content;
        padding: 10px 25px;
        display: flex;
        justify-content: center;
        align-items: center;
        transition: border-top-color 0.3s ease-in, color 0.3s ease-in;
    }

    .aktiv {
        border-top: solid 1px #D4AF37;
        color: white;
    }
    .aktiv:hover {
        border-top: solid 1px #D4AF37;
        color: white;
    }

    .inaktiv {
        border-top: solid 1px gray;
        color: gray;
    }
    .inaktiv:hover {
        border-top: solid 1px gray;
        color: gray;
    }
    .ezustFont {
        color: #eeeeee;
    }

    .aranyFont {
        width: fit-content;
        background: linear-gradient( 90deg, #a47e1b 0%, #b69121 8%, #c9a227 16%, #dbb42c 24%, #9a7009 32%, #edc531 40%, #a47e1b 48%, #b69121 56%, #c9a227 64%, #dbb42c 72%, #9a7009 80%, #edc531 88%, #a47e1b 100% );
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
    }

    .vilagosBarna {
        background: rgba(245, 238, 225, 0.9);
        background: transparent;
    }

    .egyGomb {
        background: #bfa27a;
        background: black;
        color: #D4AF37;
        border: solid 0.5px #D4AF37;
        transition: transform 0.5s ease;
    }

    .egyGomb:hover {
            background: black;
            color: #D4AF37;
            border: solid 0.5px #D4AF37;
            transform: scale(1.08);
    }
</style>